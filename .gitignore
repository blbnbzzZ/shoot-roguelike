# Godot 4 项目 .gitignore

# Godot 4 导入缓存（每个人打开项目时会自动重新生成）
.godot/

# Mono 编译缓存（如果用 C#）
.mono/
data_*/
mono_crash.*.json

# 导出产物（不需要上传，每个人自己导出）
exports/
*.pck
*.exe
*.dmg
*.x86_64
*.aarch64

# 编辑器临时文件
*.tmp
*.log
*.import

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# 系统文件
Thumbs.db

# AI 工具配置（包含隐私信息）
.workbuddy/
